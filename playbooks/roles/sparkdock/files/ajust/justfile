# vim: set ft=make :

set allow-duplicate-recipes := true
set ignore-comments := true

sparkdock_path   := env_var('HOME') + "/.local/spark/sparkdock"
default_branch   := "master"
provisioner_path := env_var_or_default('AJUST_PROVISIONER_PATH', env_var('HOME') + '/provisioner')
config_file      := env_var_or_default('AJUST_CONFIG_FILE', provisioner_path + '/config/default.yaml')

_default:
    #!/usr/bin/env bash
    echo "Welcome to AJust - SparkJust for Linux"
    echo ""
    just --justfile "{{justfile()}}" --list \
      --list-heading $'Available commands:\n' --list-prefix $' - '

# Fetch latest Sparkdock updates from the git repository.
[group('sparkdock')]
sparkdock-fetch-updates:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Fetching latest Sparkdock updates..."
    cd "{{sparkdock_path}}"
    git config --local --add safe.directory "$PWD" 2>/dev/null || true
    current_branch=$(git branch --show-current)
    if [[ "${current_branch}" != "{{default_branch}}" ]]; then
        echo "Not on {{default_branch}} branch (currently on '${current_branch}'). Aborting."
        exit 1
    fi
    git fetch origin
    if git diff --quiet HEAD "origin/{{default_branch}}"; then
        echo "Already up to date."
        exit 0
    fi
    if ! git diff --quiet || ! git diff --cached --quiet; then
        echo "Stashing local changes..."
        git stash -m "Auto-stash before update $(date)"
    fi
    echo "Updating to latest {{default_branch}}..."
    git reset --hard "origin/{{default_branch}}"
    echo "Sparkdock updated successfully."

# Skills recipes (only available once sparkdock is cloned)
import? "~/.local/spark/sparkdock/sjust/recipes/05-skills.just"

# Run the provisioner ansible-playbook with specific tags.
[group('provisioner')]
provision-tags tags:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Running ansible with tags: {{tags}}"
    sudo ansible-playbook "{{provisioner_path}}/playbooks/system.yml" \
      -i localhost, -c local \
      --tags "{{tags}}" \
      --extra-vars "@{{config_file}}"

# User customizations
import? "~/.config/ajust/100-custom.just"
