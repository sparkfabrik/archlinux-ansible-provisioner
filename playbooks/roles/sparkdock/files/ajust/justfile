# vim: set ft=make :

set allow-duplicate-recipes := true
set ignore-comments := true

sparkdock_path   := env_var('HOME') + "/.local/spark/sparkdock"
default_branch   := "master"
provisioner_path := env_var_or_default('AJUST_PROVISIONER_PATH', env_var('HOME') + '/provisioner')
config_file      := env_var_or_default('AJUST_CONFIG_FILE', provisioner_path + '/config/default.yaml')

_default:
    #!/usr/bin/env bash
    echo "Welcome to AJust - SparkJust for ArchLinux "
    echo ""
    echo "👉 Remember you can add your own tasks in ~/.config/ajust/100-custom.just"
    echo ""
    just --justfile "{{justfile()}}" _check-sparkdock-version
    just --justfile "{{justfile()}}" --list \
      --list-heading $'Available commands:\n' --list-prefix $' - '

[private]
_check-sparkdock-version:
    #!/usr/bin/env bash
    [[ -d "{{sparkdock_path}}/.git" ]] || { echo "⚠️  Sparkdock not found. Run 'ajust sparkdock-fetch-updates'."; exit 0; }
    cd "{{sparkdock_path}}"
    git config --local --add safe.directory "$PWD" 2>/dev/null || true
    dirty=0
    [[ "$(git branch --show-current)" == "{{default_branch}}" ]] || { echo "⚠️  Sparkdock on branch '$(git branch --show-current)', expected '{{default_branch}}'."; dirty=1; }
    git diff --quiet && git diff --cached --quiet || { echo "⚠️  Sparkdock has local modifications."; dirty=1; }
    if git fetch origin -q 2>/dev/null; then
        [[ "$(git rev-parse HEAD)" == "$(git rev-parse "origin/{{default_branch}}")" ]] || { echo "⚠️  Sparkdock is behind origin/{{default_branch}}."; dirty=1; }
    else
        echo "⚠️  Could not reach Sparkdock remote (offline?)."
    fi
    (( dirty )) && echo "    Run 'ajust sparkdock-fetch-updates' to update." && echo || true

# Fetch latest Sparkdock updates from the git repository.
[group('sparkdock')]
sparkdock-fetch-updates:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Fetching latest Sparkdock updates..."
    cd "{{sparkdock_path}}"
    git config --local --add safe.directory "$PWD" 2>/dev/null || true
    current_branch=$(git branch --show-current)
    if [[ "${current_branch}" != "{{default_branch}}" ]]; then
        echo "Not on {{default_branch}} branch (currently on '${current_branch}'). Aborting."
        exit 1
    fi
    git fetch origin
    if git diff --quiet HEAD "origin/{{default_branch}}"; then
        echo "Already up to date."
        exit 0
    fi
    echo "Updating to latest {{default_branch}}..."
    if ! git pull --ff-only origin "{{default_branch}}"; then
        echo "Fast-forward failed. Local clone has diverged from origin/{{default_branch}}."
        echo "Resolve manually in {{sparkdock_path}} or run: git -C {{sparkdock_path}} reset --hard origin/{{default_branch}}"
        exit 1
    fi
    echo "Sparkdock updated successfully."

# AI coding agent recipes (only available once sparkdock is cloned)
import? "~/.local/spark/sparkdock/sjust/recipes/05-ai-coding-agents.just"

# Run the provisioner ansible-playbook with specific tags.
[group('provisioner')]
provision-tags tags:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ ! -f "{{provisioner_path}}/playbooks/system.yml" ]]; then
        echo "Provisioner not found at {{provisioner_path}}"
        echo "Set AJUST_PROVISIONER_PATH to your archlinux-ansible-provisioner checkout."
        exit 1
    fi
    if [[ ! -f "{{config_file}}" ]]; then
        echo "Config file not found at {{config_file}}"
        echo "Set AJUST_CONFIG_FILE or create the file. See config/default.yaml.tpl for reference."
        exit 1
    fi
    echo "Running ansible with tags: {{tags}}"
    sudo ansible-playbook "{{provisioner_path}}/playbooks/system.yml" \
      -i localhost, -c local \
      --tags "{{tags}}" \
      --extra-vars "@{{config_file}}"

# User customizations
import? "~/.config/ajust/100-custom.just"

# Externally managed tasks (e.g. MDM)
import? "~/.local/spark/sparkdock/sjust/000-system.just"
