#!/bin/bash
# OTel headers helper for Claude Code (`otelHeadersHelper`).
# Outputs one or more "Header-Name=Value" lines on stdout. Called at Claude
# startup and periodically (CLAUDE_CODE_OTEL_HEADERS_HELPER_DEBOUNCE_MS).
#
# Configured via env vars from the org managed-settings.json (private repo):
#   SPARKFABRIK_CC_OTEL_SECRET_NAME    — Secret Manager secret id
#   SPARKFABRIK_CC_OTEL_SECRET_PROJECT — Secret Manager project id
#
# Authenticates via the user's gcloud session (no MDM token-fetch needed).
# Fails quietly (exit 0, no output) if anything is missing — Claude Code will
# call again on the next debounce cycle.
set -uo pipefail

: "${SPARKFABRIK_CC_OTEL_SECRET_NAME:?}"
: "${SPARKFABRIK_CC_OTEL_SECRET_PROJECT:?}"

TOKEN=$(gcloud secrets versions access latest \
    --secret="$SPARKFABRIK_CC_OTEL_SECRET_NAME" \
    --project="$SPARKFABRIK_CC_OTEL_SECRET_PROJECT" 2>/dev/null) || exit 0

[ -n "$TOKEN" ] && printf "Authorization=Bearer %s\n" "$TOKEN"
